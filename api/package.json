        "@types/express": "^5.0.0",
        "@types/multer": "^1.4.13",
        "@types/node": "^22.0.0",
        "@types/passport-google-oauth20": "^2.0.16",
        "@types/passport-jwt": "^4.0.1",
        "@types/passport-local": "^1.0.38",
        "@types/pg": "^8.11.0",
        "drizzle-kit": "^0.31.0",
