{
    "name": "api",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "build": "nest build",
        "dev": "nest start --watch",
        "start": "node dist/main",
        "start:debug": "nest start --debug --watch",
        "check-types": "tsc --noEmit",
        "test": "jest",
        "db:generate": "drizzle-kit generate",
