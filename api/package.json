        "@nestjs/passport": "^11.0.0",
        "@nestjs/platform-express": "^11.0.0",
        "@nestjs/swagger": "^11.4.4",
        "@nestjs/throttler": "^6.5.0",
        "bcrypt": "^6.0.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "cloudinary": "^2.9.0",
        "cookie-parser": "^1.4.7",
        "dotenv": "^16.4.7",
        "drizzle-orm": "^0.43.0",
        "helmet": "^8.2.0",
        "multer": "1.4.5-lts.2",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "passport-jwt": "^4.0.1",
